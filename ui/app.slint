import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct AgentItem {
    name: string,          // ollama launch token (e.g. "codex-app")
    display: string,       // label (e.g. "Codex App")
    is-gui: bool,
    running: bool,
    restorable: bool,      // has an ollama restore backup
    initials: string,      // badge text (e.g. "CA")
    color-index: int,      // slot into Theme.palette
}

export struct ModelItem {
    name: string,          // model name passed to ollama launch
    is-local: bool,        // true = pulled from local/remote Ollama server
}

// ---- theme ----
global Theme {
    out property <color> bg: #1e1e2e;
    out property <color> panel: #181825;
    out property <color> card: #313244;
    out property <color> accent: #89b4fa;
    out property <color> text: #cdd6f4;
    out property <color> subtext: #a6adc8;
    out property <color> green: #a6e3a1;
    out property <color> red: #f38ba8;
    out property <color> local: #94e2d5;   // teal — local model indicator
    out property <[color]> palette: [
        #89b4fa, #a6e3a1, #fab387, #cba6f7, #f38ba8, #94e2d5, #f9e2af,
        #f5c2e7, #74c7ec, #f2cdcd, #b4befe, #eba0ac, #89dceb,
    ];
    public pure function tint(i: int) -> color {
        return palette[mod(i, palette.length)];
    }
}

// ---- colored initials badge ----
component AgentBadge inherits Rectangle {
    in property <string> label;
    in property <int> color-index;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: Theme.tint(color-index);
    Text {
        text: label;
        color: #11111b;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---- small pill badge shown next to local model names ----
component LocalBadge inherits Rectangle {
    width: 34px;
    height: 16px;
    border-radius: 4px;
    background: Theme.local.with-alpha(0.18);
    Text {
        text: "local";
        color: Theme.local;
        font-size: 9px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---- custom agent dropdown (badge + name per row) ----
component AgentSelect {
    in property <[AgentItem]> items;
    in-out property <int> current-index;
    min-width: 200px;
    height: 34px;
    property <length> vis: min(items.length * 36px, 200px);
    property <int> open-tick: 0;

    property <AgentItem> cur: (current-index >= 0 && current-index < items.length)
        ? items[current-index]
        : { display: "Select agent", initials: "?", color-index: 0 };

    field := Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ta.has-hover ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 12px;
            spacing: 8px;
            AgentBadge {
                y: (parent.height - self.height) / 2;
                label: cur.initials;
                color-index: cur.color-index;
            }
            Text {
                text: cur.display;
                color: Theme.text;
                font-size: 14px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: "▾";
                color: Theme.subtext;
                font-size: 18px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }
        ta := TouchArea {
            clicked => {
                root.open-tick += 1;
                popup.show();
            }
        }
    }

    popup := PopupWindow {
        x: 0;
        // expand downward from the field, with the selected row at the head
        y: 0px;
        width: root.width;
        height: vis + 12px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: Theme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: #45475a;
            ScrollView {
                height: vis;
                viewport-y: (root.open-tick * 0px) - max(0px, min(root.current-index * 36px, items.length * 36px + 12px - vis));
                VerticalLayout {
                    padding: 6px;
                    for it[idx] in items: Rectangle {
                        height: 36px;
                        border-radius: 7px;
                        background: idx == root.current-index
                            ? Theme.accent.with-alpha(0.22)
                            : (row-ta.has-hover ? Theme.card : transparent);
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 8px;
                            alignment: start;
                            AgentBadge {
                                y: (parent.height - self.height) / 2;
                                label: it.initials;
                                color-index: it.color-index;
                            }
                            Text {
                                text: it.display;
                                color: Theme.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Rectangle {
                                width: 8px; height: 8px; border-radius: 4px;
                                y: (parent.height - self.height) / 2;
                                background: it.running ? Theme.green : transparent;
                            }
                        }
                        row-ta := TouchArea {
                            clicked => {
                                root.current-index = idx;
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---- model dropdown — shows a teal "local" badge for server models ----
component ModelSelect {
    in property <[ModelItem]> items;
    in-out property <int> current-index;
    in property <bool> enabled: true;
    min-width: 200px;
    height: 34px;
    property <length> vis: min(items.length * 36px, 200px);
    property <int> open-tick: 0;

    property <ModelItem> cur: (current-index >= 0 && current-index < items.length)
        ? items[current-index]
        : { name: "Select model", is-local: false };

    field := Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ta.has-hover ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        opacity: enabled ? 1.0 : 0.5;
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 6px;
            // teal dot shown for the selected item when it's local
            Rectangle {
                width: cur.is-local ? 7px : 0px;
                height: 7px;
                border-radius: 4px;
                y: (parent.height - self.height) / 2;
                background: cur.is-local ? Theme.local : transparent;
            }
            Text {
                text: cur.name;
                color: Theme.text;
                font-size: 14px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: "▾";
                color: Theme.subtext;
                font-size: 18px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }
        ta := TouchArea {
            enabled: root.enabled;
            clicked => {
                root.open-tick += 1;
                popup.show();
            }
        }
    }

    popup := PopupWindow {
        x: 0;
        // expand downward from the field, with the selected row at the head
        y: 0px;
        width: root.width;
        height: vis + 12px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: Theme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: #45475a;
            ScrollView {
                height: vis;
                viewport-y: (root.open-tick * 0px) - max(0px, min(root.current-index * 36px, items.length * 36px + 12px - vis));
                VerticalLayout {
                    padding: 6px;
                    for it[idx] in items: Rectangle {
                        height: 36px;
                        border-radius: 7px;
                        background: idx == root.current-index
                            ? Theme.accent.with-alpha(0.22)
                            : (row-ta.has-hover ? Theme.card : transparent);
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            spacing: 8px;
                            alignment: start;
                            Text {
                                text: it.name;
                                color: it.is-local ? Theme.local : Theme.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            // "local" pill badge — only visible for local models
                            if it.is-local: LocalBadge {
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        row-ta := TouchArea {
                            clicked => {
                                root.current-index = idx;
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---- themed text input ----
component ThemedInput {
    in-out property <string> text;
    in property <string> placeholder-text: "";
    callback accepted(string);
    height: 34px;
    min-width: 200px;

    Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ti.has-focus ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            ti := TextInput {
                text <=> root.text;
                color: Theme.text;
                font-size: 13px;
                vertical-alignment: center;
                single-line: true;
                accepted => { root.accepted(self.text); }
            }
        }
    }
}

// ---- dismissible banner (success / error) ----
component Banner {
    in property <string> message;
    in property <int> kind;   // 1 = ok (green), 2 = error (red)
    callback close();

    property <color> fg: kind == 2 ? Theme.red : Theme.green;
    property <color> bg: kind == 2 ? Theme.red.with-alpha(0.12) : Theme.green.with-alpha(0.12);

    height: 34px;
    horizontal-stretch: 1;

    animate opacity { duration: 120ms; }

    Rectangle {
        border-radius: 8px;
        background: root.bg;
        border-width: 1px;
        border-color: root.fg.with-alpha(0.25);
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 4px;
            spacing: 6px;
            Text {
                text: root.message;
                color: root.fg;
                font-size: 13px;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            // close button
            close-btn := Rectangle {
                width: 24px;
                height: 24px;
                border-radius: 6px;
                y: (parent.height - self.height) / 2;
                background: close-ta.has-hover
                    ? root.fg.with-alpha(0.18)
                    : transparent;
                Text {
                    text: "✕";
                    color: root.fg;
                    font-size: 11px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                close-ta := TouchArea {
                    clicked => { root.close(); }
                }
            }
        }
    }
}

// ---- themed button (matches the rest of the app) ----
component Btn {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked();
    height: 34px;
    min-width: 100px;

    Rectangle {
        border-radius: 8px;
        opacity: root.enabled ? 1.0 : 0.45;
        background: root.primary
            ? (ta.has-hover ? Theme.accent.brighter(0.15) : Theme.accent)
            : (ta.has-hover ? Theme.card.brighter(0.25) : Theme.card);
        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            Text {
                text: root.text;
                color: root.primary ? #11111b : Theme.text;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        ta := TouchArea {
            enabled: root.enabled;
            clicked => { root.clicked(); }
        }
    }
}

export component AppWindow inherits Window {
    title: "Llaunchpad";
    // fixed size — non resizable (min == max)
    min-width: 760px;
    max-width: 760px;
    min-height: 440px;
    max-height: 440px;
    background: Theme.bg;
    // Ensure Unicode glyphs (▾ ↻ ✕ ● ✓ ✗) render on every platform.
    // Segoe UI covers them on Windows; macOS/Linux fall back to their system font.
    default-font-family: "Segoe UI";

    in property <[AgentItem]> agents;
    in property <[string]> agent-names;
    in property <[ModelItem]> models;
    in property <string> status;
    in property <int> status-kind;   // 0 none, 1 ok, 2 error
    in property <bool> refreshing;
    in property <string> version;

    // selection indices (settable from Rust to restore last use)
    in-out property <int> sel-agent-index: -1;
    in-out property <int> sel-model-index: -1;
    // Ollama server URL (editable, persisted)
    in-out property <string> ollama-host: "http://localhost:11434";

    // resolved selections
    property <int> agent-idx: sel-agent-index;
    property <string> agent-token: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].name : "";
    property <bool> agent-running: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].running : false;
    property <bool> agent-restorable: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].restorable : false;
    property <string> model-val: (sel-model-index >= 0 && sel-model-index < models.length) ? models[sel-model-index].name : "";

    callback launch(int /*agent index*/, string /*model*/);
    callback restore(int /*agent index*/);
    callback refresh();
    callback test-connection(string /*ollama host url*/);
    callback dismiss();

    VerticalBox {
        padding: 22px;
        spacing: 20px;
        alignment: start;

        // ---- header ----
        HorizontalBox {
            alignment: space-between;
            HorizontalLayout {
                spacing: 10px;
                Image {
                    source: @image-url("../assets/icon-header.png");
                    width: 44px;
                    height: 44px;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: "Llaunchpad";
                    color: Theme.text;
                    font-size: 22px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
            }
            HorizontalBox {
                spacing: 10px;
                alignment: end;
                Text {
                    text: refreshing ? "refreshing…" : "";
                    color: Theme.subtext;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                Btn {
                    text: "↻ Refresh";
                    clicked => { root.refresh(); }
                }
            }
        }

        // ---- ollama host row ----
        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Text {
                text: "Ollama host";
                color: Theme.subtext;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
                width: 82px;
            }
            host-input := ThemedInput {
                text <=> root.ollama-host;
                placeholder-text: "http://localhost:11434";
                horizontal-stretch: 1;
                accepted(url) => { root.test-connection(url); }
            }
            Btn {
                text: "Test";
                min-width: 70px;
                clicked => { root.test-connection(root.ollama-host); }
            }
        }

        // ---- command line with inline dropdowns ----
        Text {
            text: "Command";
            color: Theme.subtext;
            font-size: 12px;
            font-weight: 700;
        }
        Rectangle {
            background: Theme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: Theme.accent.with-alpha(0.35);
            VerticalLayout {
                padding: 18px;
                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Text {
                        text: "ollama launch";
                        color: Theme.text;
                        font-size: 16px;
                        font-family: "Menlo, Consolas, DejaVu Sans Mono, monospace";
                        vertical-alignment: center;
                    }
                    agent-select := AgentSelect {
                        items: root.agents;
                        current-index <=> root.sel-agent-index;
                        min-width: 190px;
                    }
                    Text {
                        text: "--model";
                        color: Theme.text;
                        font-size: 16px;
                        font-family: "Menlo, Consolas, DejaVu Sans Mono, monospace";
                        vertical-alignment: center;
                    }
                    model-select := ModelSelect {
                        items: root.models;
                        current-index <=> root.sel-model-index;
                        enabled: root.models.length > 0;
                        min-width: 240px;
                    }
                }
            }
        }

        // ---- launch ----
        HorizontalBox {
            spacing: 12px;
            alignment: start;
            Btn {
                text: root.agent-running ? "Relaunch" : "Launch";
                primary: true;
                enabled: root.agent-token != "" && root.model-val != "";
                clicked => { root.launch(root.agent-idx, root.model-val); }
            }
            Btn {
                text: "Restore";
                primary: false;
                enabled: root.agent-restorable;
                clicked => { root.restore(root.agent-idx); }
            }
            Text {
                text: root.agent-running ? "● running" : "";
                color: Theme.green;
                font-size: 12px;
                vertical-alignment: center;
            }
        }

        // push the footer to the bottom
        Rectangle { vertical-stretch: 1; }

        // ---- footer: banner (left, stretches) + version (right) ----
        HorizontalLayout {
            spacing: 12px;
            if root.status != "": Banner {
                message: root.status;
                kind: root.status-kind;
                close => { root.dismiss(); }
            }
            if root.status == "": Rectangle {
                horizontal-stretch: 1;
                height: 34px;
            }
            Text {
                text: "v" + root.version;
                color: Theme.subtext;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}
