import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";

export struct AgentItem {
    name: string,          // ollama launch token (e.g. "codex-app")
    display: string,       // label (e.g. "Codex App")
    is-gui: bool,
    running: bool,
    installed: bool,       // app/CLI detected on this machine
    restorable: bool,      // has an ollama restore backup
    initials: string,      // badge text (e.g. "CA") — shown when no logo
    color-index: int,      // slot into Theme.palette
    logo: string,          // logo key e.g. "claude-code", "" = fall back to initials
}

export struct ModelItem {
    name: string,          // model name passed to ollama launch
    is-local: bool,        // true = pulled from local/remote Ollama server
    provider: string,      // provider slug e.g. "openai", "gemini", "ollama"
}

export struct TerminalItem {
    key: string,           // persisted key (e.g. "iterm2", "gnome-terminal")
    label: string,         // human-readable label for the dropdown
}

// ---- theme ----
global Theme {
    out property <color> bg: #1e1e2e;
    out property <color> panel: #181825;
    out property <color> card: #313244;
    out property <color> accent: #89b4fa;
    out property <color> text: #cdd6f4;
    out property <color> subtext: #a6adc8;
    out property <color> green: #a6e3a1;
    out property <color> red: #f38ba8;
    out property <color> warn: #fab387;     // peach — "not installed" indicator
    out property <color> local: #94e2d5;   // teal — local model indicator
    out property <[color]> palette: [
        #89b4fa, #a6e3a1, #fab387, #cba6f7, #f38ba8, #94e2d5, #f9e2af,
        #f5c2e7, #74c7ec, #f2cdcd, #b4befe, #eba0ac, #89dceb,
    ];
    public pure function tint(i: int) -> color {
        return palette[mod(i, palette.length)];
    }
}

// ---- vector icon (24x24 viewBox, stroke-based, minimal). Pass `name` to pick one. ----
component Icon {
    in property <string> name;          // "chevron-down" | "refresh" | "close" | "gear" | "dot" | "check"
    in property <color> color: Theme.text;
    in property <length> size: 16px;
    in property <length> stroke: 1.75px;

    out property <string> commands:
        name == "chevron-down" ? "M 6 9 L 12 15 L 18 9" :
        name == "refresh" ? "M 20 12 A 8 8 0 1 1 12 4 L 12 4 M 12 4 L 8 4 M 12 4 L 12 8" :
        name == "close" ? "M 6 6 L 18 18 M 18 6 L 6 18" :
        name == "gear" ? "M 13 2 L 11 2 L 10.6 4.2 L 8.8 5.1 L 6.9 4 L 5.5 5.5 L 6.6 7.4 L 5.7 9.2 L 3.5 9.6 L 3.5 11.6 L 5.7 12 L 6.6 13.8 L 5.5 15.7 L 6.9 17.1 L 8.8 16 L 10.6 16.9 L 11 19.2 L 13 19.2 L 13.4 16.9 L 15.2 16 L 17.1 17.1 L 18.5 15.7 L 17.4 13.8 L 18.3 12 L 20.5 11.6 L 20.5 9.6 L 18.3 9.2 L 17.4 7.4 L 18.5 5.5 L 17.1 4 L 15.2 5.1 L 13.4 4.2 L 13 2 Z M 12 9 A 3 3 0 1 1 12 15 A 3 3 0 1 1 12 9 Z" :
        name == "check" ? "M 5 12 L 10 17 L 19 7" :
        name == "dot" ? "M 12 12 m -4 0 a 4 4 0 1 0 8 0 a 4 4 0 1 0 -8 0 Z" :
        "";
    out property <bool> filled: name == "gear" || name == "dot";

    width: size;
    height: size;
    Path {
        width: 100%;
        height: 100%;
        fill: root.filled ? root.color : transparent;
        stroke: root.filled ? transparent : root.color;
        stroke-width: root.stroke;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: root.commands;
    }
}


// ---- colored initials badge ----
// ---- agent badge: logo PNG if known, otherwise colored initials ----
component AgentBadge inherits Rectangle {
    in property <string> label;
    in property <int> color-index;
    in property <string> logo;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    clip: true;
    background: logo != "" ? #ffffff : Theme.tint(color-index);

    if logo == "" : Text {
        text: label;
        color: #11111b;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if logo == "claude-code" : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/claude-code.png"); image-fit: contain; }
    if logo == "codex"       : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/codex.png");       image-fit: contain; }
    if logo == "opencode"    : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/opencode.png");    image-fit: contain; }
    if logo == "hermes"      : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/hermes.png");      image-fit: contain; }
    if logo == "openclaw"    : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/openclaw.png");    image-fit: contain; }
    if logo == "cursor"      : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/cursor.png");      image-fit: contain; }
    if logo == "windsurf"    : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/windsurf.png");    image-fit: contain; }
    if logo == "copilot"     : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/copilot.png");     image-fit: contain; }
    if logo == "cline"       : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/cline.png");       image-fit: contain; }
    if logo == "amp"         : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/amp.png");         image-fit: contain; }
    if logo == "goose"       : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/goose.png");       image-fit: contain; }
    if logo == "vscode"      : Image { width: 26px; height: 26px; source: @image-url("../assets/logos/vscode.png");      image-fit: contain; }
}

// ---- small pill badge shown next to local model names ----
component LocalBadge inherits Rectangle {
    width: 42px;
    height: 20px;
    border-radius: 5px;
    background: Theme.local.with-alpha(0.18);
    Text {
        text: "local";
        color: Theme.local;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---- small pill badge shown when an agent's app/CLI is missing ----
component NotInstalledBadge inherits Rectangle {
    width: 98px;
    height: 20px;
    border-radius: 5px;
    background: Theme.warn.with-alpha(0.18);
    Text {
        text: "not installed";
        color: Theme.warn;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ---- plain string dropdown used for the terminal list ----
component TerminalSelect {
    in property <[TerminalItem]> items;
    in-out property <int> current-index;
    min-width: 200px;
    height: 34px;
    property <length> vis: min(items.length * 36px, 200px);
    property <int> open-tick: 0;

    property <TerminalItem> cur: (current-index >= 0 && current-index < items.length)
        ? items[current-index]
        : { key: "", label: "Select terminal" };

    field := Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ta.has-hover ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 6px;
            Text {
                text: cur.label;
                color: Theme.text;
                font-size: 14px;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            Icon {
                name: "chevron-down";
                color: Theme.subtext;
                size: 18px;
                stroke: 1.75px;
                y: (parent.height - self.height) / 2;
            }
        }
        ta := TouchArea {
            clicked => {
                root.open-tick += 1;
                popup.show();
            }
        }
    }

    popup := PopupWindow {
        x: 0;
        y: 0px;
        width: max(root.width, 260px);
        height: vis + 12px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: Theme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: #45475a;
            clip: true;
            ScrollView {
                height: vis;
                viewport-y: (root.open-tick * 0px) - max(0px, min(root.current-index * 36px, items.length * 36px + 12px - vis));
                VerticalLayout {
                    padding: 6px;
                    for it[idx] in items: Rectangle {
                        height: 36px;
                        border-radius: 7px;
                        clip: true;
                        background: idx == root.current-index
                            ? Theme.accent.with-alpha(0.22)
                            : (row-ta.has-hover ? Theme.card : transparent);
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: start;
                            Text {
                                text: it.label;
                                color: Theme.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                        row-ta := TouchArea {
                            clicked => {
                                root.current-index = idx;
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---- custom agent dropdown (badge + name per row) ----
component AgentSelect {
    in property <[AgentItem]> items;
    in-out property <int> current-index;
    min-width: 200px;
    height: 34px;
    property <length> vis: min(items.length * 36px, 200px);
    property <int> open-tick: 0;

    property <AgentItem> cur: (current-index >= 0 && current-index < items.length)
        ? items[current-index]
        : { display: "Select agent", initials: "?", color-index: 0, installed: true, logo: "" };

    field := Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ta.has-hover ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 12px;
            spacing: 8px;
            AgentBadge {
                y: (parent.height - self.height) / 2;
                label: cur.initials;
                color-index: cur.color-index;
                logo: cur.logo;
                opacity: cur.installed ? 1.0 : 0.55;
            }
            Text {
                text: cur.display;
                color: Theme.text;
                font-size: 14px;
                vertical-alignment: center;
                opacity: cur.installed ? 1.0 : 0.55;
            }
            Rectangle { horizontal-stretch: 1; }
            Icon {
                name: "chevron-down";
                color: Theme.subtext;
                size: 18px;
                stroke: 1.75px;
                y: (parent.height - self.height) / 2;
            }
        }
        ta := TouchArea {
            clicked => {
                root.open-tick += 1;
                popup.show();
            }
        }
    }

    popup := PopupWindow {
        x: 0;
        // expand downward from the field, with the selected row at the head
        y: 0px;
        // popup may be wider than the field so the "not installed" badge fits
        // alongside long agent names without overflowing the panel
        width: max(root.width, 320px);
        height: vis + 12px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: Theme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: #45475a;
            clip: true;
            ScrollView {
                height: vis;
                viewport-y: (root.open-tick * 0px) - max(0px, min(root.current-index * 36px, items.length * 36px + 12px - vis));
                VerticalLayout {
                    padding: 6px;
                    for it[idx] in items: Rectangle {
                        height: 36px;
                        border-radius: 7px;
                        clip: true;
                        background: idx == root.current-index
                            ? Theme.accent.with-alpha(0.22)
                            : (row-ta.has-hover ? Theme.card : transparent);
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 8px;
                            alignment: start;
                            AgentBadge {
                                y: (parent.height - self.height) / 2;
                                label: it.initials;
                                color-index: it.color-index;
                                logo: it.logo;
                                opacity: it.installed ? 1.0 : 0.55;
                            }
                            Text {
                                text: it.display;
                                color: Theme.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                                opacity: it.installed ? 1.0 : 0.55;
                            }
                            if !it.installed: NotInstalledBadge {
                                y: (parent.height - self.height) / 2;
                            }
                            Rectangle {
                                width: 8px; height: 8px; border-radius: 4px;
                                y: (parent.height - self.height) / 2;
                                background: it.running ? Theme.green : transparent;
                            }
                        }
                        row-ta := TouchArea {
                            clicked => {
                                root.current-index = idx;
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---- provider logo badge ----
component ProviderLogo inherits Rectangle {
    in property <string> provider;
    width: 22px;
    height: 22px;

    if provider == "openai"   : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/openai.png");   image-fit: contain; }
    if provider == "gemini"   : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/gemini.png");   image-fit: contain; }
    if provider == "gemma"    : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/gemma.png");    image-fit: contain; }
    if provider == "mistral"  : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/mistral.png");  image-fit: contain; }
    if provider == "deepseek" : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/deepseek.png"); image-fit: contain; }
    if provider == "qwen"     : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/qwen.png");     image-fit: contain; }
    if provider == "zhipu"    : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/zhipu.png");    image-fit: contain; }
    if provider == "moonshot" : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/moonshot.png"); image-fit: contain; }
    if provider == "nvidia"   : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/nvidia.png");   image-fit: contain; }
    if provider == "minimax"  : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/minimax.png");  image-fit: contain; }
    if provider == "ollama"   : Image { width: 22px; height: 22px; source: @image-url("../assets/logos/ollama.png");   image-fit: contain; }
}

// ---- model dropdown — shows provider logo + teal "local" badge for server models ----
component ModelSelect {
    in property <[ModelItem]> items;
    in-out property <int> current-index;
    in property <bool> enabled: true;
    min-width: 200px;
    height: 34px;
    property <length> vis: min(items.length * 36px, 200px);
    property <int> open-tick: 0;

    property <ModelItem> cur: (current-index >= 0 && current-index < items.length)
        ? items[current-index]
        : { name: "Select model", is-local: false, provider: "ollama" };

    field := Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ta.has-hover ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        opacity: enabled ? 1.0 : 0.5;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 12px;
            spacing: 8px;
            ProviderLogo {
                y: (parent.height - self.height) / 2;
                provider: cur.provider;
            }
            Text {
                text: cur.name;
                color: cur.is-local ? Theme.local : Theme.text;
                font-size: 14px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Icon {
                name: "chevron-down";
                color: Theme.subtext;
                size: 18px;
                stroke: 1.75px;
                y: (parent.height - self.height) / 2;
            }
        }
        ta := TouchArea {
            enabled: root.enabled;
            clicked => {
                root.open-tick += 1;
                popup.show();
            }
        }
    }

    popup := PopupWindow {
        x: 0;
        // expand downward from the field, with the selected row at the head
        y: 0px;
        width: root.width;
        height: vis + 12px;
        close-policy: close-on-click-outside;
        Rectangle {
            background: Theme.panel;
            border-radius: 10px;
            border-width: 1px;
            border-color: #45475a;
            ScrollView {
                height: vis;
                viewport-y: (root.open-tick * 0px) - max(0px, min(root.current-index * 36px, items.length * 36px + 12px - vis));
                VerticalLayout {
                    padding: 6px;
                    for it[idx] in items: Rectangle {
                        height: 36px;
                        border-radius: 7px;
                        background: idx == root.current-index
                            ? Theme.accent.with-alpha(0.22)
                            : (row-ta.has-hover ? Theme.card : transparent);
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 8px;
                            alignment: start;
                            ProviderLogo {
                                y: (parent.height - self.height) / 2;
                                provider: it.provider;
                            }
                            Text {
                                text: it.name;
                                color: it.is-local ? Theme.local : Theme.text;
                                font-size: 14px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            // "local" pill badge — only visible for local models
                            if it.is-local: LocalBadge {
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        row-ta := TouchArea {
                            clicked => {
                                root.current-index = idx;
                                popup.close();
                            }
                        }
                    }
                }
            }
        }
    }
}

// ---- themed text input ----
component ThemedInput {
    in-out property <string> text;
    in property <string> placeholder-text: "";
    callback accepted(string);
    height: 34px;
    min-width: 200px;

    Rectangle {
        background: Theme.card;
        border-radius: 8px;
        border-width: ti.has-focus ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        HorizontalLayout {
            padding-left: 10px;
            padding-right: 10px;
            ti := TextInput {
                text <=> root.text;
                color: Theme.text;
                font-size: 13px;
                vertical-alignment: center;
                single-line: true;
                accepted => { root.accepted(self.text); }
            }
        }
        // placeholder overlay — visible when the field is empty and unfocused
        if root.text == "" && !ti.has-focus: Text {
            x: 10px;
            y: (parent.height - self.height) / 2;
            text: root.placeholder-text;
            color: Theme.subtext.with-alpha(0.5);
            font-size: 13px;
        }
    }
}

// ---- dismissible banner (success / error) ----
component Banner {
    in property <string> message;
    in property <int> kind;   // 1 = ok (green), 2 = error (red)
    callback close();

    property <color> fg: kind == 2 ? Theme.red : Theme.green;
    property <color> bg: kind == 2 ? Theme.red.with-alpha(0.12) : Theme.green.with-alpha(0.12);

    height: 34px;
    horizontal-stretch: 1;

    animate opacity { duration: 120ms; }

    Rectangle {
        border-radius: 8px;
        background: root.bg;
        border-width: 1px;
        border-color: root.fg.with-alpha(0.25);
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 4px;
            spacing: 6px;
            Text {
                text: root.message;
                color: root.fg;
                font-size: 13px;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            // close button
            close-btn := Rectangle {
                width: 24px;
                height: 24px;
                border-radius: 6px;
                y: (parent.height - self.height) / 2;
                background: close-ta.has-hover
                    ? root.fg.with-alpha(0.18)
                    : transparent;
                Icon {
                    name: "close";
                    color: root.fg;
                    size: 18px;
                    stroke: 1.75px;
                    y: (parent.height - self.height) / 2;
                    x: (parent.width - self.width) / 2;
                }
                close-ta := TouchArea {
                    clicked => { root.close(); }
                }
            }
        }
    }
}

// ---- themed button (matches the rest of the app) ----
component Btn {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked();
    height: 34px;
    min-width: 100px;

    Rectangle {
        border-radius: 8px;
        opacity: root.enabled ? 1.0 : 0.45;
        background: root.primary
            ? (ta.has-hover ? Theme.accent.brighter(0.15) : Theme.accent)
            : (ta.has-hover ? Theme.card.brighter(0.25) : Theme.card);
        HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            Text {
                text: root.text;
                color: root.primary ? #11111b : Theme.text;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        ta := TouchArea {
            enabled: root.enabled;
            clicked => { root.clicked(); }
        }
    }
}

// ---- small square icon button (toolbar actions: refresh, settings, ...) ----
component IconBtn {
    in property <string> name;          // icon name (see Icon component)
    in property <bool> active: false;   // toggle-on highlight (e.g. settings open)
    in property <bool> enabled: true;
    callback clicked();
    width: 32px;
    height: 32px;

    Rectangle {
        border-radius: 8px;
        background: root.active
            ? Theme.accent.with-alpha(0.22)
            : (ta.has-hover ? Theme.card : transparent);
        border-width: root.active ? 1px : 0px;
        border-color: Theme.accent.with-alpha(0.5);
        opacity: root.enabled ? 1.0 : 0.45;
        Icon {
            name: root.name;
            color: root.active ? Theme.accent : Theme.subtext;
            size: 20px;
            stroke: 1.85px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
        }
        ta := TouchArea {
            enabled: root.enabled;
            clicked => { root.clicked(); }
        }
    }
}

// ---- settings side panel (slides in from the right) ----
component SettingsPanel {
    in property <bool> open;
    in property <string> version-label: "";
    in property <[TerminalItem]> terminals;
    in-out property <int> sel-terminal-index: 0;
    in-out property <string> sel-terminal-key: "";
    callback close();
    callback select-terminal(string /*terminal key*/);
    width: 360px;
    height: 100%;

    Rectangle {
        background: Theme.panel;
        border-width: 1px;
        border-color: #45475a;

        VerticalLayout {
            padding: 22px;
            spacing: 16px;

            // header row
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Settings";
                    color: Theme.text;
                    font-size: 18px;
                    font-weight: 800;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                close-btn := Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: 6px;
                    y: (parent.height - self.height) / 2;
                    background: close-ta.has-hover ? Theme.card : transparent;
                    Icon {
                        name: "close";
                        color: Theme.subtext;
                        size: 18px;
                        stroke: 1.75px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    close-ta := TouchArea {
                        clicked => { root.close(); }
                    }
                }
            }

            // divider
            Rectangle {
                height: 1px;
                background: #45475a;
            }

            // ---- terminal selector ----
            Rectangle {
                background: Theme.card.with-alpha(0.45);
                border-radius: 10px;
                border-width: 1px;
                border-color: Theme.accent.with-alpha(0.25);
                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    Text {
                        text: "Terminal";
                        color: Theme.text;
                        font-size: 14px;
                        font-weight: 700;
                    }
                    Text {
                        text: "Terminal emulator used to launch CLI agents. Only installed emulators are listed.";
                        color: Theme.subtext;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    terminal-select := TerminalSelect {
                        items: root.terminals;
                        current-index <=> root.sel-terminal-index;
                        horizontal-stretch: 1;
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }

            // footer
            Text {
                text: "Llaunchpad " + root.version-label;
                color: Theme.subtext.with-alpha(0.6);
                font-size: 11px;
                horizontal-alignment: center;
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Llaunchpad";
    // window/taskbar icon (shown by the OS when the app is running)
    icon: @image-url("../assets/icon-header.png");
    // fixed size — non resizable (min == max)
    min-width: 760px;
    max-width: 760px;
    min-height: 440px;
    max-height: 440px;
    background: Theme.bg;
    // "Segoe UI Symbol" is used as the default because it contains the Unicode
    // glyphs used as icons (▾ ↻ ✕ ● ✓ ✗) while still rendering Latin text
    // acceptably. femtovg does not do automatic font fallback, so without this
    // those characters appear as empty boxes on Windows.
    // On macOS/Linux this font will not be found; the system default is used.
    default-font-family: "Segoe UI Symbol";

    in property <[AgentItem]> agents;
    in property <[string]> agent-names;
    in property <[ModelItem]> models;
    in property <string> status;
    in property <int> status-kind;   // 0 none, 1 ok, 2 error
    in property <bool> refreshing;
    in property <string> version;

    // selection indices (settable from Rust to restore last use)
    in-out property <int> sel-agent-index: -1;
    in-out property <int> sel-model-index: -1;
    // Ollama server URL (editable, persisted)
    in-out property <string> ollama-host: "http://localhost:11434";
    // Working directory the agent is launched in (editable, persisted; empty = inherit)
    in-out property <string> working-dir: "";

    // ---- terminal selection ----
    in property <[TerminalItem]> terminals;
    in-out property <int> sel-terminal-index: 0;
    out property <string> sel-terminal-key: (sel-terminal-index >= 0 && sel-terminal-index < terminals.length)
        ? terminals[sel-terminal-index].key
        : "";

    // resolved selections
    property <int> agent-idx: sel-agent-index;
    property <string> agent-token: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].name : "";
    property <bool> agent-running: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].running : false;
    property <bool> agent-installed: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].installed : true;
    property <bool> agent-restorable: (sel-agent-index >= 0 && sel-agent-index < agents.length) ? agents[sel-agent-index].restorable : false;
    property <string> model-val: (sel-model-index >= 0 && sel-model-index < models.length) ? models[sel-model-index].name : "";

    callback launch(int /*agent index*/, string /*model*/);
    callback restore(int /*agent index*/);
    callback refresh();
    callback test-connection(string /*ollama host url*/);
    callback pick-directory();
    callback dismiss();
    callback select-terminal(string /*terminal key*/);

    // ---- settings side panel state ----
    in-out property <bool> settings-open: false;
    callback toggle-settings();
    callback close-settings();


    // ---- main content ----
    VerticalBox {
        width: 100%;
        height: 100%;
        padding: 22px;        spacing: 20px;
        alignment: start;

        // ---- header ----
        HorizontalBox {
            alignment: space-between;
            HorizontalLayout {
                spacing: 10px;
                Image {
                    source: @image-url("../assets/icon-header.png");
                    width: 44px;
                    height: 44px;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: "Llaunchpad";
                    color: Theme.text;
                    font-size: 22px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
            }
            HorizontalBox {
                spacing: 8px;
                alignment: end;
                Text {
                    text: refreshing ? "refreshing…" : "";
                    color: Theme.subtext;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                refresh-btn := Rectangle {
                    height: 34px;
                    min-width: 100px;
                    border-radius: 8px;
                    background: refresh-ta.has-hover ? Theme.card.brighter(0.25) : Theme.card;
                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 16px;
                        spacing: 8px;
                        alignment: center;
                        Icon {
                            name: "refresh";
                            color: Theme.text;
                            size: 18px;
                            stroke: 2.2px;
                            y: (parent.height - self.height) / 2;
                        }
                        Text {
                            text: "Refresh";
                            color: Theme.text;
                            font-size: 14px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    refresh-ta := TouchArea {
                        clicked => { root.refresh(); }
                    }
                }
                IconBtn {
                    name: "gear";
                    active: root.settings-open;
                    clicked => { root.toggle-settings(); }
                }
            }
        }

        // ---- ollama host row ----
        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Text {
                text: "Ollama host";
                color: Theme.subtext;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
                width: 82px;
            }
            host-input := ThemedInput {
                text <=> root.ollama-host;
                placeholder-text: "http://localhost:11434";
                horizontal-stretch: 1;
                accepted(url) => { root.test-connection(url); }
            }
            Btn {
                text: "Test";
                min-width: 70px;
                clicked => { root.test-connection(root.ollama-host); }
            }
        }

        // ---- working directory row ----
        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Text {
                text: "Directory";
                color: Theme.subtext;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
                width: 82px;
            }
            dir-input := ThemedInput {
                text <=> root.working-dir;
                placeholder-text: "Working directory";
                horizontal-stretch: 1;
            }
            Btn {
                text: "Browse…";
                min-width: 90px;
                clicked => { root.pick-directory(); }
            }
        }

        // ---- command line with inline dropdowns ----
        Text {
            text: "Command";
            color: Theme.subtext;
            font-size: 12px;
            font-weight: 700;
        }
        Rectangle {
            background: Theme.panel;
            border-radius: 14px;
            border-width: 1px;
            border-color: Theme.accent.with-alpha(0.35);
            VerticalLayout {
                padding: 18px;
                HorizontalLayout {
                    spacing: 10px;
                    alignment: start;
                    Text {
                        text: "ollama launch";
                        color: Theme.text;
                        font-size: 16px;
                        font-family: "Consolas";
                        vertical-alignment: center;
                    }
                    agent-select := AgentSelect {
                        items: root.agents;
                        current-index <=> root.sel-agent-index;
                        min-width: 190px;
                    }
                    Text {
                        text: "--model";
                        color: Theme.text;
                        font-size: 16px;
                        font-family: "Menlo, Consolas, DejaVu Sans Mono, monospace";
                        vertical-alignment: center;
                    }
                    model-select := ModelSelect {
                        items: root.models;
                        current-index <=> root.sel-model-index;
                        enabled: root.models.length > 0;
                        min-width: 240px;
                    }
                }
            }
        }

        // ---- launch ----
        HorizontalBox {
            spacing: 12px;
            alignment: start;
            Btn {
                text: root.agent-running ? "Relaunch" : "Launch";
                primary: true;
                enabled: root.agent-token != "" && root.model-val != "" && root.agent-installed;
                clicked => { root.launch(root.agent-idx, root.model-val); }
            }
            Btn {
                text: "Restore";
                primary: false;
                enabled: root.agent-restorable;
                clicked => { root.restore(root.agent-idx); }
            }
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Icon {
                    name: "dot";
                    color: !root.agent-installed && root.agent-token != ""
                        ? Theme.warn
                        : (root.agent-running ? Theme.green : transparent);
                    size: 10px;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: root.agent-token != "" && !root.agent-installed
                        ? "not installed"
                        : (root.agent-running ? "running" : "");
                    color: !root.agent-installed && root.agent-token != "" ? Theme.warn : Theme.green;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }

        // push the footer to the bottom
        Rectangle { vertical-stretch: 1; }


        // ---- footer: banner (left, stretches) + version (right) ----
        HorizontalLayout {
            spacing: 12px;
            if root.status != "": Banner {
                message: root.status;
                kind: root.status-kind;
                close => { root.dismiss(); }
            }
            if root.status == "": Rectangle {
                horizontal-stretch: 1;
                height: 34px;
            }
            Text {
                text: "v" + root.version;
                color: Theme.subtext;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }

    // ---- overlay layer: dimmed scrim + sliding side panel (drawn on top of main content) ----
    settings-panel-rect := Rectangle {
        width: 100%;
        height: 100%;
        background: root.settings-open ? #000000.with-alpha(0.35) : transparent;
        scrim-ta := TouchArea {
            visible: root.settings-open;
            width: 100%;
            height: 100%;
            clicked => { root.close-settings(); }
        }
        // sliding panel docked to the right edge
        settings-panel := SettingsPanel {
            x: root.settings-open ? (parent.width - self.width) : parent.width;
            y: 0;
            width: 360px;
            height: 100%;
            open: root.settings-open;
            version-label: "v" + root.version;
            terminals: root.terminals;
            sel-terminal-index <=> root.sel-terminal-index;
            sel-terminal-key <=> root.sel-terminal-key;
            select-terminal(key) => { root.select-terminal(key); }
            close => { root.close-settings(); }
            animate x { duration: 220ms; easing: ease-out; }
        }
    }
}
